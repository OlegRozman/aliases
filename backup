alias dx_bp_kb='sh $script_path/app-bkp.sh'

dx_ync() {
    if [ -f "$script_path/home.flag" ]; then   # home.flag - флага хоста
       restic -r $dir_bkp/appj --password-file $script_path/app-repo.pwd restore latest:/home/cs/app --exclude-file $script_path/app-exclude.lst --delete --target /home/cs/app
    elif [ -f "$script_path/job.flag" ]; then
       restic -r $dir_bkp/apph --password-file $script_path/app-repo.pwd restore latest:/home/cs/app --exclude-file $script_path/app-exclude.lst --delete --target /home/cs/app
    fi
}

dx_nap() {
    echo &&
    if pgrep -x dropbox >/dev/null; then
        echo "      DROPBOX STATUS" && echo &&      
        dropbox status
    else
        echo "DROPBOX НЕ ЗАПУЩЕН. ЗАПУСКАЮ..."
        dropbox start
    fi &&
    echo && echo "------------------------------------------------" && 
    echo && echo  "      HOME REPO" && \
    restic -r $dir_bkp/apph --password-file $script_path/app-repo.pwd snapshots | tail -14 | awk '{print $1, $2, $3}' | sed -n '2p;6p;10p' &&
    echo && echo "\n      JOB REPO" && \
    restic -r $dir_bkp/appj --password-file $script_path/app-repo.pwd snapshots | tail -14 | awk '{print $1, $2, $3}' | sed -n '2p;6p;10p'
}


