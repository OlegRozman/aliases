# ................................ S3

alias bp_kb='bash $script_path/s3_app.sh'

ync() {
	source $script_path/s3_bp.key
    if [ -f "$script_path/home.flag" ]; then   # home.flag - флага хоста
       restic -r $bp_app_path/job --password-file $script_path/s3_app.pwd restore latest:/home/cs/app --exclude-file $script_path/app-exclude.lst --delete --target /home/cs/app
    elif [ -f "$script_path/job.flag" ]; then
       restic -r $bp_app_path/home --password-file $script_path/s3_app.pwd restore latest:/home/cs/app --exclude-file $script_path/app-exclude.lst --delete --target /home/cs/app
    fi
}

nap() { source $script_path/s3_bp.key
		echo && echo  "      HOME REPO" && 
		restic -r $bp_app_path/home --password-file $script_path/s3_app.pwd snapshots | tail -14 | awk '{print $1, $2, $3}' | sed -n '2p;6p;10p' && 
		echo && echo "      JOB REPO" &&
		restic -r  $bp_app_path/job --password-file $script_path/s3_app.pwd snapshots | tail -14 | awk '{print $1, $2, $3}' | sed -n '2p;6p;10p'
}
	

alias repo_h='source $script_path/s3_bp.key && restic -r $bp_app_path/home --password-file $script_path/s3_app.pwd'
alias repo_j='source $script_path/s3_bp.key && restic -r $bp_app_path/job --password-file $script_path/s3_app.pwd'


