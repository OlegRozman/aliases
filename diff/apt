
alias upd='sudo apt update'
alias ups='sudo apt update && sudo apt upgrade'                    
alias ill='sudo apt install'
rmv () { sudo apt remove $1 && sudo apt autoremove }
alias ilist='apt list --installed | grep'
alias repolist='cat /etc/apt/sources.list && ls /etc/apt/sources.list.d/*.sources | cat'

